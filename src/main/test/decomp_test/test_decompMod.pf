module test_decompMod

  ! Tests of decompMod

  use funit
  use decompMod
  use shr_kind_mod , only : r8 => shr_kind_r8

  implicit none

  @TestCase
  type, extends(TestCase) :: TestDecompMod
   contains
     procedure :: setUp
     procedure :: tearDown
     procedure :: create_simpleSingleDecomp
  end type TestDecompMod

  ! Make sure sizes are different in order to catch certain type of errors
  integer, parameter :: ni = 2
  integer, parameter :: nj = 3

contains

  ! ========================================================================
  ! Helper routines
  ! ========================================================================

  subroutine setUp(this)
    class(TestDecompMod), intent(inout) :: this

    call this%create_simpleSingleDecomp( ni=ni, nj=nj )
  end subroutine setUp

  subroutine tearDown(this)
    class(TestDecompMod), intent(inout) :: this

    call decompmod_clean()

  end subroutine tearDown

  subroutine create_simpleSingleDecomp(this, ni, nj)
    use unittestSubgridMod, only : set_decomp_info
    class(TestDecompMod), intent(inout) :: this
    integer, intent(in) :: ni, nj

    integer :: g

    call set_decomp_info( ni=ni, nj=nj )
    call decompmod_allocate_gindex( ni*nj )
    do g = 1, ni*nj
      ! since no ocean points are masked out global and grc are identical
      gindex_global(g) = g
      gindex_grc(g) = g
      ! Assume subgrid levels are all one per higher level, so everything is the same
      gindex_lun(g) = g
      gindex_col(g) = g
      gindex_patch(g) = g
    end do

  end subroutine create_simpleSingleDecomp

  ! ========================================================================
  ! Begin tests
  ! ========================================================================

  @Test
  subroutine test_get_clump_bounds(this)
    class(TestDecompMod), intent(inout) :: this

    type(bounds_type) :: bounds
    integer :: n

    do n = 1, procinfo%nclumps
       call get_clump_bounds(n, bounds)
       @assertEqual(bounds%level, bounds_level_clump)
       @assertEqual(bounds%clump_index, n)
    end do
  end subroutine test_get_clump_bounds

  @Test
  subroutine test_get_proc_bounds(this)
    class(TestDecompMod), intent(inout) :: this

    type(bounds_type) :: bounds

    ! Add optional argument, just to test that it can handle it
    call get_proc_bounds(bounds, allow_call_from_threaded_region=.true.)
    @assertEqual(bounds%level, bounds_level_proc)
    @assertEqual(bounds%clump_index, -1)
  end subroutine test_get_proc_bounds

  @Test
  subroutine test_proc_clump_bounds_equal(this)
    class(TestDecompMod), intent(inout) :: this

    type(bounds_type) :: bounds_clump, bounds_proc

    @assertTrue(procinfo%nclumps == 1)
    call get_clump_bounds(1, bounds_clump)
    call get_proc_bounds(bounds_proc)
    @assertEqual(bounds_proc%begg, bounds_clump%begg)
    @assertEqual(bounds_proc%endg, bounds_clump%endg)
  end subroutine test_proc_clump_bounds_equal

  @Test
  subroutine test_get_global_index(this)
    class(TestDecompMod), intent(inout) :: this

    integer :: g, n

    do g = procinfo%begg, procinfo%endg
       n = get_global_index(g, subgrid_level_gridcell)
       @assertEqual(n, g)
       ! Will be the same for all subgrid levels since they are all one to one
       n = get_global_index(g, subgrid_level_landunit)
       @assertEqual(n, g)
       n = get_global_index(g, subgrid_level_column)
       @assertEqual(n, g)
       n = get_global_index(g, subgrid_level_patch)
       @assertEqual(n, g)
    end do
  end subroutine test_get_global_index

  @Test
  subroutine test_get_global_index_bad_values_fails(this)
    class(TestDecompMod), intent(inout) :: this

    character(len=:), allocatable :: expected_msg
    integer :: idx

    idx = get_global_index(0, subgrid_level_gridcell, donot_abort_on_badindex=.true. )
    @assertEqual(idx, -1)

  end subroutine test_get_global_index_bad_values_fails

  @Test
  subroutine test_get_global_index_bad_subgrid_fails(this)
    class(TestDecompMod), intent(inout) :: this

    character(len=:), allocatable :: expected_msg
    integer :: idx

    idx = get_global_index(1, subgrid_level_unspecified, donot_abort_on_badindex=.true. )
    @assertEqual(idx, -1)

  end subroutine test_get_global_index_bad_subgrid_fails


  @Test
  subroutine test_get_subgrid_level_gindex_for_lndgrid(this)
    class(TestDecompMod), intent(inout) :: this

    integer :: g, n
    integer, pointer :: gindex(:) => NULL()

    call get_subgrid_level_gindex(subgrid_level_lndgrid, gindex)
    do g = procinfo%begg, procinfo%endg
       n = gindex(g)
       @assertEqual(n, g)
    end do
  end subroutine test_get_subgrid_level_gindex_for_lndgrid

  @Test
  subroutine test_calc_globalxy_indices(this)
    class(TestDecompMod), intent(inout) :: this

    type(bounds_type) :: bounds
    integer :: g
    integer :: i, j
    integer :: expect_i(ni*nj), expect_j(ni*nj)

    ! Expected indices is just the pattern on the simple 2D grid with no mask
    g = 0
    do j = 1, nj
      do i = 1, ni
        g = g + 1
        expect_i(g) = i
        expect_j(g) = j
      end do
    end do
    call get_proc_bounds(bounds)
    ! Make sure begg is 1, as that is assumed here
    @assertEqual(bounds%begg, 1)
    @assertEqual(bounds%endg, ni*nj)
    do g = bounds%begg, bounds%endg
      call procinfo%calc_globalxy_indices( g, i, j )
      @assertEqual(i, expect_i(g) )
      @assertEqual(j, expect_j(g) )
    end do

  end subroutine test_calc_globalxy_indices

  @Test
  subroutine test_calc_globalxy_fails(this)
    class(TestDecompMod), intent(inout) :: this

    integer :: g
    integer :: i, j

    ! IF g is less than begg i and j should be undefined as -1
    g = 0
    call procinfo%calc_globalxy_indices( g, i, j )
    @assertEqual(i, -1)
    @assertEqual(j, -1)
    ! IF g is greater than endg i and j should be undefined as -1
    g = ni*nj + 1
    call procinfo%calc_globalxy_indices( g, i, j )
    @assertEqual(i, -1)
    @assertEqual(j, -1)
    ! If nglob_x is not set
    nglob_x = -1
    call procinfo%calc_globalxy_indices( g, i, j )
    @assertEqual(i, -1)
    @assertEqual(j, -1)
    ! If nglob_y is not set
    nglob_y = -1
    call procinfo%calc_globalxy_indices( g, i, j )
    @assertEqual(i, -1)
    @assertEqual(j, -1)

  end subroutine test_calc_globalxy_fails

  @Test
  subroutine test_calc_globalxy_fails_when_not_allocated(this)
    class(TestDecompMod), intent(inout) :: this

    integer :: g
    integer :: i, j

    call decompmod_clean()
    g = 1
    call procinfo%calc_globalxy_indices( g, i, j )
    @assertEqual(i, -1)
    @assertEqual(j, -1)

  end subroutine test_calc_globalxy_fails_when_not_allocated

  @Test
  subroutine test_calc_global_index_fromij(this)
    class(TestDecompMod), intent(inout) :: this

    integer :: expect_g
    integer :: i, j, g

    ! Expected indices is just the pattern on the simple 2D grid with no mask
    expect_g = 0
    do j = 1, nj
      do i = 1, ni
        expect_g = expect_g + 1
        g = procinfo%calc_global_index_fromij( i, j )
        @assertEqual(g, expect_g)
      end do
    end do
  end subroutine test_calc_global_index_fromij

  @Test
  subroutine test_calc_global_index_fromij_reversed(this)
    class(TestDecompMod), intent(inout) :: this

    integer :: expect_g
    integer :: i, j, g

    ! Clean the decomp, and then create a new one with ni and nj reversed
    call decompmod_clean()
    call this%create_simpleSingleDecomp( ni=nj, nj=ni )
    expect_g = 0
    ! Remember ni/nj is reversed here
    do j = 1, ni
      do i = 1, nj
        expect_g = expect_g + 1
        g = procinfo%calc_global_index_fromij( i, j)
        @assertEqual(g, expect_g)
      end do
    end do
  end subroutine test_calc_global_index_fromij_reversed

  @Test
  subroutine test_calc_ijindices_from_full_global_index_fails(this)
    class(TestDecompMod), intent(inout) :: this

    integer :: gidx ! Global idnex
    integer :: i, j

    ! IF gidx is less than 1 i and j should be undefined as -1
    gidx = 0
    call calc_ijindices_from_full_global_index( gidx, i, j )
    @assertEqual(i, -1)
    @assertEqual(j, -1)

    ! IF gidx is greater than grid size  i and j should be undefined as -1
    gidx = ni*nj + 1
    call calc_ijindices_from_full_global_index( gidx, i, j )
    @assertEqual(i, -1)
    @assertEqual(j, -1)

  end subroutine test_calc_ijindices_from_full_global_index_fails

end module test_decompMod
